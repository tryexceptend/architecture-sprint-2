        <mxCell id="9y2hPWxCLwX-Bn1uh1Jj-11" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Запросы к кешу&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;" parent="1" vertex="1">
