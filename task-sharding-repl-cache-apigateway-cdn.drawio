        <mxCell id="ZDMWXZoiJUmzCXupuomX-43" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Запросы от внешних систем в базу данных&amp;nbsp;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;" parent="1" vertex="1">
